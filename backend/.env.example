PORT=3000
NODE_ENV=development

# SQL Server connection
# For local Windows dev, use Windows Authentication:
DB_USE_WINDOWS_AUTH=true
DB_SERVER=localhost
DB_PORT=1433
DB_NAME=workshop_advisor
DB_ENCRYPT=false
DB_TRUST_CERT=true

# SQL login (set DB_USE_WINDOWS_AUTH=false to use these)
DB_USER=sa
DB_PASSWORD=YourStrong@Passw0rd

JWT_SECRET=change-this-to-a-secure-random-string-in-production
JWT_EXPIRES_IN=24h

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=workshop-advisor-uploads

OPENAI_API_KEY=
VAHAN_API_KEY=
BOODMO_API_KEY=
PARTSTECH_API_KEY=

CORS_ORIGIN=*
